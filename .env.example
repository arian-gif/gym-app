# ----------------------------------------------------------------------
# Sample environment variables for Gym Tracker.
#
# 1. Copy this file to ".env"   (cp .env.example .env)
# 2. Fill in the real values below.
# 3. `netlify dev` loads .env automatically for local development.
#
# For the deployed site, DO NOT commit .env — instead set these same keys
# in Netlify: Site settings -> Environment variables.
# ----------------------------------------------------------------------

# Your MongoDB Atlas connection string (required).
# Atlas -> Connect -> Drivers. Replace USER, PASSWORD and the cluster host.
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Your login password (required). Whatever you put here is what you type
# on the app's login screen. Pick something only you know.
APP_TOKEN=change-me-to-a-strong-password

# Database name (optional, defaults to "gymtracker").
MONGODB_DB=gymtracker
